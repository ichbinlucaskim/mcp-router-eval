# Copy to .env and fill in. .env is gitignored. All values optional.
# Only needed for the OpenAIEmbedder path (published-number reproduction; see ADR 0003).

# OpenAI (text-embedding-ada-002)
# OPENAI_API_KEY=

# Azure OpenAI (alternative provider used by the reference paper)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
